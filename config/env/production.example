APP_NAME=FastAPI Template
ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+asyncpg://app:replace-me@production-db:5432/app
SECRET_KEY=replace-with-a-random-production-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=fastapi-template
JWT_AUDIENCE=fastapi-template-api
CORS_ORIGINS=["https://example.com"]
ALLOWED_HOSTS=["api.example.com"]
LOG_LEVEL=INFO
