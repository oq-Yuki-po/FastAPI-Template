APP_NAME=FastAPI Template Staging
ENVIRONMENT=staging
DEBUG=false
DATABASE_URL=postgresql+asyncpg://app:replace-me@staging-db:5432/app
SECRET_KEY=replace-with-a-random-staging-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=fastapi-template-staging
JWT_AUDIENCE=fastapi-template-api
CORS_ORIGINS=["https://staging.example.com"]
ALLOWED_HOSTS=["staging-api.example.com"]
LOG_LEVEL=INFO
